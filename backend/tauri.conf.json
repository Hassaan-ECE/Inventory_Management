{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inventory Management",
  "version": "0.1.0",
  "identifier": "com.inventory.management",
  "build": {
    "beforeDevCommand": "bun run dev:frontend",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "bun run build:frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Inventory Management v0.1.0",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "Syed Hassaan Shah",
    "copyright": "Copyright (c) 2026 Syed Hassaan Shah",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    },
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3RkJFMzBGRURFNzJCMzcKUldRM0srZnREK1A3Wnl5dkVteGdHMFVKWmJMK0FmZlp6MW1TNFlZMVMyU21STTNZMGpWK3h1bXQK",
      "endpoints": [
        "https://github.com/Hassaan-ECE/Inventory_Management/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
